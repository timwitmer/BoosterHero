// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Users table (athletes, coaches, admins)
model User {
  id              String   @id @default(uuid())
  clerkUserId     String?  @unique @map("clerk_user_id")
  email           String   @unique
  firstName       String   @map("first_name")
  lastName        String   @map("last_name")
  role            String   @default("athlete") // 'athlete', 'coach', 'admin'
  phone           String?
  profileImageUrl String?  @map("profile_image_url")
  schoolName      String?  @map("school_name")
  isActive        Boolean  @default(true) @map("is_active")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  campaigns        Campaign[]
  notificationLogs NotificationLog[]
  auditLogs        AuditLog[]

  @@index([clerkUserId])
  @@index([email])
  @@index([role])
  @@map("users")
}

// Campaigns table
model Campaign {
  id              String    @id @default(uuid())
  userId          String    @map("user_id")
  slug            String    @unique
  title           String
  description     String?
  sport           String // 'football', 'basketball', 'soccer', etc.
  teamName        String?   @map("team_name")
  schoolName      String?   @map("school_name")
  athletePhotoUrl String?   @map("athlete_photo_url")
  fundraisingGoal Decimal   @map("fundraising_goal") @db.Decimal(10, 2)
  gridRows        Int       @default(10) @map("grid_rows")
  gridCols        Int       @default(10) @map("grid_cols")
  status          String    @default("draft") // 'draft', 'active', 'paused', 'completed'
  qrCodeUrl       String?   @map("qr_code_url")
  activatedAt     DateTime? @map("activated_at")
  startDate       DateTime? @map("start_date")
  endDate         DateTime? @map("end_date")
  completedAt     DateTime? @map("completed_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  gridSquares      GridSquare[]
  transactions     Transaction[]
  notificationLogs NotificationLog[]

  @@index([userId])
  @@index([slug])
  @@index([status])
  @@index([sport])
  @@index([createdAt(sort: Desc)])
  @@map("campaigns")
}

// Grid squares table
model GridSquare {
  id          String    @id @default(uuid())
  campaignId  String    @map("campaign_id")
  positionX   Int       @map("position_x")
  positionY   Int       @map("position_y")
  squareValue Decimal   @map("square_value") @db.Decimal(10, 2)
  status      String    @default("available") // 'available', 'pending', 'sold'
  lockedUntil DateTime? @map("locked_until")
  version     Int       @default(0) // For optimistic concurrency control
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  campaign          Campaign           @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  purchasedSquares  PurchasedSquare[]

  @@unique([campaignId, positionX, positionY])
  @@index([campaignId])
  @@index([status])
  @@index([lockedUntil])
  @@map("grid_squares")
}

// Transactions table
model Transaction {
  id                  String    @id @default(uuid())
  campaignId          String    @map("campaign_id")
  paypalOrderId       String    @unique @map("paypal_order_id")
  paypalTransactionId String?   @map("paypal_transaction_id")
  donorEmail          String    @map("donor_email")
  donorName           String    @map("donor_name")
  amount              Decimal   @db.Decimal(10, 2)
  currency            String    @default("USD")
  status              String    @default("pending") // 'pending', 'completed', 'failed', 'refunded'
  paypalPayerId       String?   @map("paypal_payer_id")
  paypalCaptureId     String?   @map("paypal_capture_id")
  paymentMethod       String?   @map("payment_method") // 'paypal', 'card'
  feeAmount           Decimal?  @map("fee_amount") @db.Decimal(10, 2)
  netAmount           Decimal?  @map("net_amount") @db.Decimal(10, 2)
  failureReason       String?   @map("failure_reason")
  metadata            Json?
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")
  completedAt         DateTime? @map("completed_at")

  campaign          Campaign           @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  purchasedSquares  PurchasedSquare[]
  notificationLogs  NotificationLog[]

  @@index([campaignId])
  @@index([paypalOrderId])
  @@index([status])
  @@index([donorEmail])
  @@index([createdAt(sort: Desc)])
  @@map("transactions")
}

// Purchased squares (junction table for many-to-many relationship)
model PurchasedSquare {
  id            String   @id @default(uuid())
  transactionId String   @map("transaction_id")
  squareId      String   @unique @map("square_id") // Each square can only be purchased once
  donorName     String   @map("donor_name")
  donorInitials String?  @map("donor_initials")
  purchasedAt   DateTime @default(now()) @map("purchased_at")

  transaction Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  square      GridSquare  @relation(fields: [squareId], references: [id], onDelete: Cascade)

  @@index([transactionId])
  @@index([squareId])
  @@index([purchasedAt(sort: Desc)])
  @@map("purchased_squares")
}

// Notification logs
model NotificationLog {
  id               String    @id @default(uuid())
  userId           String?   @map("user_id")
  campaignId       String?   @map("campaign_id")
  transactionId    String?   @map("transaction_id")
  notificationType String    @map("notification_type") // 'purchase_confirmation', 'campaign_milestone', etc.
  recipientEmail   String    @map("recipient_email")
  subject          String?
  status           String    @default("pending") // 'pending', 'sent', 'failed'
  provider         String? // 'sendgrid', 'ses', etc.
  providerMessageId String?  @map("provider_message_id")
  errorMessage     String?   @map("error_message")
  sentAt           DateTime? @map("sent_at")
  createdAt        DateTime  @default(now()) @map("created_at")

  user        User?        @relation(fields: [userId], references: [id], onDelete: SetNull)
  campaign    Campaign?    @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  transaction Transaction? @relation(fields: [transactionId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([campaignId])
  @@index([status])
  @@index([createdAt(sort: Desc)])
  @@map("notification_logs")
}

// Webhook events (for idempotency and debugging)
model WebhookEvent {
  id           String    @id @default(uuid())
  provider     String // 'paypal'
  eventType    String    @map("event_type")
  eventId      String    @unique @map("event_id") // PayPal event ID
  payload      Json
  status       String    @default("pending") // 'pending', 'processing', 'processed', 'failed'
  processedAt  DateTime? @map("processed_at")
  errorMessage String?   @map("error_message")
  retryCount   Int       @default(0) @map("retry_count")
  createdAt    DateTime  @default(now()) @map("created_at")

  @@index([eventId])
  @@index([status])
  @@index([createdAt(sort: Desc)])
  @@map("webhook_events")
}

// Audit log (for compliance and debugging)
model AuditLog {
  id         String   @id @default(uuid())
  userId     String?  @map("user_id")
  entityType String   @map("entity_type") // 'campaign', 'transaction', 'user', etc.
  entityId   String   @map("entity_id")
  action     String // 'create', 'update', 'delete', 'status_change'
  oldValues  Json?    @map("old_values")
  newValues  Json?    @map("new_values")
  ipAddress  String?  @map("ip_address")
  userAgent  String?  @map("user_agent")
  createdAt  DateTime @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([entityType, entityId])
  @@index([createdAt(sort: Desc)])
  @@map("audit_logs")
}
